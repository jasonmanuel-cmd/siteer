# Supabase configuration
# Get these from your Supabase project dashboard
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# Preferred for SiteER server routes: anon key + request secret enforced by RLS
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_REQUEST_SECRET=generate-a-long-random-secret
# Optional fallback if you use a real service role key instead
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Email configuration (Resend)
# Sign up at https://resend.com and get your API key
RESEND_API_KEY=your-resend-api-key-here
CONTACT_EMAIL=admin@yourdomain.com
SENDER_EMAIL=SiteER <reports@yourdomain.com>

# Payment processing (Square)
# Get these from your Square developer dashboard
SQUARE_ACCESS_TOKEN=your-square-access-token-here
SQUARE_LOCATION_ID=your-square-location-id-here
SQUARE_ENVIRONMENT=production

# App configuration
# This should be your production domain or Vercel URL
NEXT_PUBLIC_APP_URL=https://siteer.app
GOOGLE_PAGESPEED_API_KEY=your-google-pagespeed-api-key-here
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_ID/exec

# Report token signing
# Generate a long random secret and keep it stable across deploys.
REPORT_TOKEN_SECRET=generate-a-long-random-secret
CRON_SECRET=generate-a-long-random-secret
