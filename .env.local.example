# Supabase — required. Both crash the app if missing.
# Find these in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Your deployed app URL (no trailing slash).
# Used to build shareable report links sent in emails.
# Falls back to http://localhost:3000 in dev — MUST be set in production.
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Contact email shown on the Pricing page CTAs.
CONTACT_EMAIL=hello@yourdomain.com

# Resend — required for email delivery.
# Create a key at https://resend.com → API Keys
# Also set SENDER_EMAIL to a domain you have verified in Resend.
RESEND_API_KEY=re_your_resend_api_key_here
SENDER_EMAIL=SiteER <reports@yourdomain.com>
