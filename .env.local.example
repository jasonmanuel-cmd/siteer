# Supabase — required. The app accepts either a service-role key or the
# anon key plus a server-only request secret enforced by RLS.
# Find these in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_REQUEST_SECRET=generate-a-long-random-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Your deployed app URL (no trailing slash).
# Used to build shareable report links sent in emails.
# Falls back to http://localhost:3000 in dev — MUST be set in production.
NEXT_PUBLIC_APP_URL=https://yourdomain.com
GOOGLE_PAGESPEED_API_KEY=your-google-pagespeed-api-key-here
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_ID/exec

# Stable secret for signed stateless report links and payment-return validation.
# Use a long random string and keep it the same in every environment that should
# be able to open the same report links.
REPORT_TOKEN_SECRET=generate-a-long-random-secret
CRON_SECRET=generate-a-long-random-secret

# Contact email — shown on pricing page, receives quote notification emails.
CONTACT_EMAIL=hello@yourdomain.com

# Resend — required for email delivery.
# Create a key at https://resend.com → API Keys
# Set SENDER_EMAIL to a domain you have verified in Resend.
RESEND_API_KEY=re_your_resend_api_key_here
SENDER_EMAIL=SiteER <reports@yourdomain.com>

# Square — required for the $20 Quick ER Audit payment flow.
# 1. Create a Square Developer account at developer.squareup.com
# 2. Create an application → copy Application ID
# 3. Go to Locations → copy your Location ID
# 4. Go to Credentials → copy your Access Token (Production or Sandbox)
# Set SQUARE_ENVIRONMENT=sandbox for testing, production for real payments.
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_LOCATION_ID=your-square-location-id
SQUARE_ENVIRONMENT=sandbox
