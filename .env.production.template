# SiteER — Vercel Environment Variables (Template)
# ⚠️ DO NOT COMMIT ACTUAL SECRETS TO THIS FILE
# Instead, use Vercel Dashboard → Project Settings → Environment Variables
# OR use: vercel env add <NAME> production
#
# This template shows which variables are required. Fill in your actual values
# in the Vercel Dashboard only, never in version control.

# Supabase configuration
# Get from: supabase.com → Your Project → Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_REQUEST_SECRET=GENERATE_A_LONG_RANDOM_SECRET
# Optional if you prefer a real service-role key instead of the anon-key + secret pattern
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Email (Resend)
# Get from: resend.com → API Keys
RESEND_API_KEY=YOUR_RESEND_API_KEY
CONTACT_EMAIL=admin@yourdomain.com
SENDER_EMAIL=SiteER <reports@yourdomain.com>

# Payment (Square)
# Get from: developer.squareup.com → Production Credentials
SQUARE_ACCESS_TOKEN=YOUR_SQUARE_ACCESS_TOKEN
SQUARE_LOCATION_ID=YOUR_SQUARE_LOCATION_ID
SQUARE_ENVIRONMENT=production

# App configuration
NEXT_PUBLIC_APP_URL=https://siteer.app
GOOGLE_PAGESPEED_API_KEY=YOUR_GOOGLE_PAGESPEED_API_KEY
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_ID/exec
GOOGLE_SHEETS_WEBHOOK_SECRET=GENERATE_A_LONG_RANDOM_SECRET

# Optional structured data fields. Leave blank unless they are real.
LOCAL_BUSINESS_NAME=SiteER
LOCAL_BUSINESS_PHONE=
LOCAL_BUSINESS_STREET=
LOCAL_BUSINESS_CITY=Bakersfield
LOCAL_BUSINESS_REGION=CA
LOCAL_BUSINESS_POSTAL_CODE=
LOCAL_BUSINESS_COUNTRY=US
LOCAL_BUSINESS_LATITUDE=
LOCAL_BUSINESS_LONGITUDE=

# Stable secret for signed report links and payment confirmation tokens
REPORT_TOKEN_SECRET=GENERATE_A_LONG_RANDOM_SECRET
CRON_SECRET=GENERATE_A_LONG_RANDOM_SECRET

